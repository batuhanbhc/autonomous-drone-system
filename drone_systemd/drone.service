[Unit]
Description=Drone Docker Stack
After=docker.service
Requires=docker.service

[Service]
Type=simple
User=batuhan
WorkingDirectory=/home/batuhan/drone-project/ros2_docker
ExecStart=/usr/bin/docker compose up
ExecStop=/usr/bin/docker compose down
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
